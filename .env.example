# WhatsApp Integration
# Número de WhatsApp para onde os leads serão enviados
# Formato: código do país + DDD + número (sem espaços ou caracteres especiais)
NEXT_PUBLIC_WHATSAPP_NUMBER=5548991964517

# Cloud API WhatsApp
# Token gerado no Meta Business Manager - system user
WHATSAPP_TOKEN=seu_token_aqui

# ID do número de WhatsApp (encontrar em Business Manager > WhatsApp > Numbers)
WHATSAPP_PHONE_NUMBER_ID=1918397195720476

# Token de verificação para o webhook (você escolhe uma string segura)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=seu_token_seguro_aqui

# Chave de API para endpoint de envio de mensagens
WHATSAPP_API_KEY=sua_chave_api_segura_aqui

# Google Analytics
NEXT_PUBLIC_GA_ID=

# Meta Pixel
NEXT_PUBLIC_PIXEL_ID=

# Integrações CRM (opcional)
ZOHO_WEBHOOK_URL=
ACTIVECAMPAIGN_WEBHOOK_URL=
RD_STATION_WEBHOOK_URL=
N8N_WEBHOOK_URL=

